# Django production settings
DJANGO_SECRET_KEY=replace-this-with-a-long-random-production-secret
DJANGO_DEBUG=0

# Render example:
# DJANGO_ALLOWED_HOSTS=your-service-name.onrender.com,your-custom-domain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-service-name.onrender.com,https://your-custom-domain.com
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# HTTPS/proxy settings for Render production
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_PROXY_SSL_HEADER=1

# Render PostgreSQL provides this automatically when linked from render.yaml.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
